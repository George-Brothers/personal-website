{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/George%20Brothers.dc", "destination": "/", "permanent": true },
    { "source": "/About.dc", "destination": "/about", "permanent": true },
    { "source": "/Now.dc", "destination": "/now", "permanent": true },
    { "source": "/Connect.dc", "destination": "/connect", "permanent": true },
    { "source": "/Work.dc", "destination": "/work", "permanent": true }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [
      { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
      { "key": "X-Content-Type-Options", "value": "nosniff" },
      { "key": "X-Frame-Options", "value": "DENY" },
      { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
    ]},
    { "source": "/assets/(.*)", "headers": [
      { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
    ]},
    { "source": "/(css|js)/(.*)", "headers": [
      { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
    ]}
  ]
}
